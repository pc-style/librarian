---
import { Image } from 'astro:assets';
import DraftContentNotice from 'virtual:starlight/components/DraftContentNotice';
import { LinkButton } from '@astrojs/starlight/components';

const PAGE_TITLE_ID = '_top';

const { data } = Astro.locals.starlightRoute.entry;
const { title = data.title, tagline, image, actions = [] } = data.hero || {};

const imageAttrs = {
	loading: 'eager' as const,
	decoding: 'async' as const,
	width: 400,
	height: 400,
	alt: image?.alt || '',
};

let darkImage: ImageMetadata | undefined;
let lightImage: ImageMetadata | undefined;
let rawHtml: string | undefined;
if (image) {
	if ('file' in image) {
		darkImage = image.file;
	} else if ('dark' in image) {
		darkImage = image.dark;
		lightImage = image.light;
	} else {
		rawHtml = image.html;
	}
}
---

<div class="hero" aria-labelledby={PAGE_TITLE_ID}>
	<div class="archive-field" aria-hidden="true"></div>
	{
		darkImage && (
			<Image
				src={darkImage}
				{...imageAttrs}
				class:list={{ 'light:sl-hidden': Boolean(lightImage) }}
			/>
		)
	}
	{lightImage && <Image src={lightImage} {...imageAttrs} class="dark:sl-hidden" />}
	{rawHtml && <div class="hero-html sl-flex" set:html={rawHtml} />}
	<div class="sl-flex stack">
		<div class="sl-flex copy">
			<p class="eyebrow">Public repo and web research</p>
			<h1 id={PAGE_TITLE_ID} data-page-title set:html={title} />
			{data.draft && <DraftContentNotice />}
			{tagline && <div class="tagline" set:html={tagline} />}
		</div>
		{
			actions.length > 0 && (
				<div class="sl-flex actions">
					{actions.map(
						({ attrs: { class: className, ...attrs } = {}, icon, link: href, text, variant }) => (
							<LinkButton {href} {variant} icon={icon?.name} class:list={[className, 'action']} {...attrs}>
								{text}
								{icon?.html && <Fragment set:html={icon.html} />}
							</LinkButton>
						)
					)}
				</div>
			)
		}
		<slot />
	</div>
</div>

<style>
	@layer starlight.core {
		.hero {
			position: relative;
			isolation: isolate;
			display: grid;
			grid-template-columns: 100%;
			align-items: center;
			gap: 1rem;
			min-height: min(42rem, calc(100svh - 7rem));
			padding-block: clamp(2.5rem, 8vw, 5.5rem);
			overflow: hidden;
		}

		.archive-field {
			position: absolute;
			inset: -2rem max(-50vw, -24rem);
			z-index: -1;
			background:
				radial-gradient(circle at 18% 34%, color-mix(in srgb, var(--sl-color-accent) 22%, transparent), transparent 34rem),
				linear-gradient(90deg, transparent 0 3.3rem, color-mix(in srgb, var(--sl-color-accent) 14%, transparent) 3.35rem 3.42rem, transparent 3.48rem 7rem),
				linear-gradient(180deg, color-mix(in srgb, var(--sl-color-bg) 92%, transparent), transparent 42%);
			background-size: auto, 7rem 100%, auto;
			opacity: 0.55;
			pointer-events: none;
		}

		.hero > img,
		.hero > .hero-html {
			object-fit: contain;
			width: min(58%, 16rem);
			height: auto;
			margin-inline: auto;
			filter: drop-shadow(var(--lib-shadow));
		}

		.stack {
			flex-direction: column;
			gap: clamp(1.35rem, 3vw, 2rem);
			max-width: 58rem;
			text-align: start;
		}

		.copy {
			flex-direction: column;
			gap: 0.95rem;
			align-items: flex-start;
		}

		.copy > * {
			max-width: 62ch;
		}

		.eyebrow {
			margin: 0;
			font-family: var(--lib-font-mono);
			font-size: clamp(0.72rem, 1.1vw, 0.82rem);
			font-weight: 500;
			letter-spacing: 0.16em;
			line-height: 1.3;
			text-transform: uppercase;
			color: var(--sl-color-accent-high);
		}

		h1 {
			max-width: 11ch;
			font-family: var(--lib-font-serif);
			font-size: clamp(4.25rem, 14vw, 9.5rem);
			font-weight: 600;
			letter-spacing: -0.07em;
			line-height: 0.82;
			color: var(--sl-color-white);
			text-wrap: balance;
		}

		.tagline {
			font-family: var(--lib-font-mono);
			font-size: clamp(0.9rem, 1.6vw, 1.05rem);
			letter-spacing: 0.035em;
			line-height: 1.75;
			color: var(--sl-color-gray-2);
		}

		.actions {
			gap: 0.75rem;
			flex-wrap: wrap;
			justify-content: flex-start;
		}

		:global(.hero .sl-link-button.action) {
			border-radius: var(--lib-radius-sm);
			font-family: var(--lib-font-mono);
			font-size: 0.86rem;
			letter-spacing: 0.015em;
			box-shadow: none;
		}

		:global(.hero .sl-link-button.action.primary) {
			border-color: var(--sl-color-accent-high);
			background: var(--sl-color-accent);
			color: var(--sl-color-black);
		}

		:global(.hero .sl-link-button.action.minimal) {
			border-color: color-mix(in srgb, var(--sl-color-gray-5) 70%, transparent);
			color: var(--sl-color-gray-2);
		}

		:global(.hero .sl-link-button.action:focus-visible) {
			outline: 2px solid var(--sl-color-accent-high);
			outline-offset: 4px;
		}

		@media (min-width: 50rem) {
			.hero {
				grid-template-columns: minmax(0, 1fr) minmax(12rem, 20rem);
				gap: clamp(2rem, 6vw, 5rem);
				padding-block: clamp(3.25rem, 8vh, 5.75rem);
			}

			.hero > img,
			.hero > .hero-html {
				order: 2;
				width: min(100%, 19rem);
			}
		}

		@media (max-width: 49.99rem) {
			.hero {
				min-height: auto;
				padding-block: 3.25rem 2.5rem;
			}

			.stack,
			.copy {
				align-items: center;
				text-align: center;
			}

			h1 {
				font-size: clamp(3.75rem, 22vw, 6.75rem);
			}

			.actions {
				justify-content: center;
			}
		}

		:root[data-theme='light'] .archive-field {
			opacity: 0.38;
			background:
				radial-gradient(circle at 18% 34%, color-mix(in srgb, var(--sl-color-accent) 18%, transparent), transparent 32rem),
				linear-gradient(90deg, transparent 0 3.3rem, color-mix(in srgb, var(--sl-color-accent) 16%, transparent) 3.35rem 3.42rem, transparent 3.48rem 7rem);
		}

		@media (prefers-reduced-motion: reduce) {
			.hero,
			.hero * {
				scroll-behavior: auto;
			}
		}
	}
</style>
